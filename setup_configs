
Build (from inside the venv):
    pyinstaller konstance.spec --clean --noconfirm

Output:
    dist/Konstance/Konstance.exe   (onedir mode)


import os
from PyInstaller.utils.hooks import (
    collect_all,
    collect_submodules,
    collect_data_files,
    collect_dynamic_libs,
)

block_cipher = None
project_root = os.path.abspath(SPECPATH)


tg_datas, tg_binaries, tg_hiddenimports = collect_all('telegram')
httpx_datas, httpx_binaries, httpx_hiddenimports = collect_all('httpx')
httpcore_datas, httpcore_binaries, httpcore_hiddenimports = collect_all('httpcore')
ultra_datas, ultra_binaries, ultra_hiddenimports = collect_all('ultralytics')


ov_datas, ov_binaries, ov_hiddenimports = collect_all('openvino')
ov_binaries += collect_dynamic_libs('openvino')

torch_datas, torch_binaries, torch_hiddenimports = collect_all('torch')


ctk_datas = collect_data_files('customtkinter')


webview_datas, webview_binaries, webview_hiddenimports = collect_all('webview')


app_datas = []
for asset in ['splash_bg.png', 'agpl_logo.png', 'konstance.ico', 'LICENSE.txt']:
    p = os.path.join(project_root, asset)
    if os.path.exists(p):
        app_datas.append((p, '.'))


hidden = [
    # UI
    'customtkinter',
    'tkinter',
    'tkinter.filedialog',
    'PIL',
    'PIL._tkinter_finder',
    'PIL.Image',
    'PIL.ImageTk',


    'cv2',
    'numpy',


    'paramiko',
    'paramiko.transport',
    'cryptography',
    'cryptography.hazmat.backends.openssl',
    'requests',
    'urllib3',
    'websocket',
    'websocket._app',


    'psutil',


    'webview',
    'webview.platforms.winforms',
    'clr',
    'clr_loader',


    'main',
    'protocol',
    'vision',
    'hardware_control',
    'file_manager',
    'bed_mesh_manager',
    'viewer_app',
    'telegram_manager',
    'telegram_window',
]
hidden += tg_hiddenimports
hidden += httpx_hiddenimports
hidden += httpcore_hiddenimports
hidden += ultra_hiddenimports
hidden += ov_hiddenimports
hidden += torch_hiddenimports
hidden += webview_hiddenimports
hidden += collect_submodules('telegram.ext')

excludes = [
    'tensorflow',
    'tensorboard',
    'keras',
    'jax',
    'mxnet',
    'paddle',
    'IPython',
    'ipykernel',
    'notebook',
    'jupyter',
    'jupyterlab',
    'nbconvert',
    'nbformat',



a = Analysis(
    ['launcher.py'],
    pathex=[project_root],
    binaries=(
        tg_binaries
        + httpx_binaries
        + httpcore_binaries
        + ultra_binaries
        + ov_binaries
        + torch_binaries
        + webview_binaries
    ),
    datas=(
        tg_datas
        + httpx_datas
        + httpcore_datas
        + ultra_datas
        + ov_datas
        + torch_datas
        + ctk_datas
        + webview_datas
        + app_datas
    ),
    hiddenimports=hidden,
    hookspath=[],
    hooksconfig={},
    runtime_hooks=[],
    excludes=excludes,
    win_no_prefer_redirects=False,
    win_private_assemblies=False,
    cipher=block_cipher,
    noarchive=False,
)

pyz = PYZ(a.pure, a.zipped_data, cipher=block_cipher)

icon_path = os.path.join(project_root, 'konstance.ico')
icon_arg = icon_path if os.path.exists(icon_path) else None

exe = EXE(
    pyz,
    a.scripts,
    [],
    exclude_binaries=True,
    name='Konstance',
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=False,                 
    console=False,             
    disable_windowed_traceback=False,
    argv_emulation=False,
    target_arch=None,
    codesign_identity=None,
    entitlements_file=None,
    icon=icon_arg,
)

coll = COLLECT(
    exe,
    a.binaries,
    a.zipfiles,
    a.datas,
    strip=False,
    upx=False,
    upx_exclude=[],
    name='Konstance',
)
